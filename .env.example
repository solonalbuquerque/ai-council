# ====== Chaves de API dos modelos (preencha as que for usar) ======
# Sem nenhuma chave, o app sobe mas não consegue rodar conversas.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ====== Ferramentas (opcionais) ======
# Busca web: se TAVILY_API_KEY estiver vazio, usa fallback DuckDuckGo (best-effort).
TAVILY_API_KEY=
# Apify (necessário para a ferramenta apify_run):
APIFY_TOKEN=

# ====== Banco ======
# No docker-compose isto já é definido automaticamente. Para rodar local sem
# Docker, aponte para seu Postgres, ex.:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aicouncil
