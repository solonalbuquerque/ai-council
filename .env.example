# ====== Chaves de API dos modelos (preencha as que for usar) ======
# Opcional se usar CLIs locais (npm run dev + /settings).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ====== Ferramentas (opcionais) ======
# Busca web: se TAVILY_API_KEY estiver vazio, usa fallback DuckDuckGo (best-effort).
TAVILY_API_KEY=
# Apify (necessário para a ferramenta apify_run):
APIFY_TOKEN=

# ====== Banco ======
# npm run dev define DATABASE_URL automaticamente (Postgres Docker em localhost:5433).
# Só descomente se rodar uvicorn manualmente:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/aicouncil
