# ====== API keys (fill in the ones you use) ======
# Optional if using local CLIs (npm run dev + /settings).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ====== Tools (optional) ======
# Web search: if TAVILY_API_KEY is empty, falls back to DuckDuckGo (best-effort).
TAVILY_API_KEY=
# Apify (required for the apify_run tool):
APIFY_TOKEN=

# ====== Database ======
# npm run dev sets DATABASE_URL automatically (Docker Postgres on localhost:5433).
# Uncomment only if running uvicorn manually:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/aicouncil
